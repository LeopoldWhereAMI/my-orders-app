{
  "name": "my-orders-app",
  "private": true,
  "version": "1.0.0",
  "author": {
    "name": "Karabin"
  },
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"cross-env BROWSER=none yarn vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "clean": "rimraf dist release",
    "build": "npm run clean && npm run check && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "yarn build && electron-builder",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "check": "npm run lint && npm run typecheck && npm run test:run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.0"
  },
  "build": {
    "appId": "com.myorders.app",
    "productName": "Срочные заказы",
    "icon": "public/myAppIcon.ico",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
